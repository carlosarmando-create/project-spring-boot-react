FROM node:22-alpine AS deps
WORKDIR /app

COPY package.json ./
RUN npm install

FROM node:22-alpine AS build
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

ARG NEXT_PUBLIC_API_URL=http://localhost:8080/api
ARG NEXT_PUBLIC_API_ASSET_URL=http://localhost:8080
ARG API_URL_INTERNAL=http://backend:8080/api
ARG API_ASSET_URL_INTERNAL=http://backend:8080

ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_ASSET_URL=$NEXT_PUBLIC_API_ASSET_URL
ENV API_URL_INTERNAL=$API_URL_INTERNAL
ENV API_ASSET_URL_INTERNAL=$API_ASSET_URL_INTERNAL

RUN npm run build

FROM node:22-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

COPY --from=build /app/.next/standalone ./
COPY --from=build /app/.next/static ./.next/static
COPY --from=build /app/public ./public

EXPOSE 3000

CMD ["node", "server.js"]
